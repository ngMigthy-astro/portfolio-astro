---
import { MessageCircle } from '@lucide/astro';

const whatsappNumber = "524622847901";
const message = "Hola Cesar, vi tu portfolio y me gustaría contactarte.";
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(message)}`;
---

<a
  href={whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Enviar mensaje por WhatsApp"
  class="fixed bottom-6 right-6 z-50 flex items-center justify-center w-14 h-14 bg-[#25D366] rounded-full shadow-lg hover:bg-[#1ebe57] transition-colors duration-300 hover:scale-110"
>
  <MessageCircle size={28} class="text-white" />
</a>
