---
const {
  education = [
    {
      title: "Formación continua",
      institution: "Cursos en línea",
      period: "2022 - Actualidad",
      description:
        "Formación constante en desarrollo web moderno: JavaScript, Angular, React, Astro y mejores prácticas de desarrollo frontend y backend.",
    },
    {
      title: "Ing. en Tecnologías de la Información",
      institution: "Universidad UNIDEG",
      period: "2017 - 2021",
      description:
        "Formación integral en programación, bases de datos, redes y administración de sistemas. Desarrollo de habilidades de trabajo en equipo, pensamiento analítico y resolución de problemas.",
    },
    {
      title: "Bachillerato",
      institution: "Preparatoria SABES",
      period: "2014 - 2017",
      description:
        "Base académica sólida que contribuyó al desarrollo del pensamiento crítico y habilidades de aprendizaje autónomo.",
    },
  ],
  workExperience = [
    {
      title: "Desarrollador Web",
      company: "Secretaría de Finanzas del Edo. de Gto.",
      period: "Ago 2023 - Actualidad",
      description:
        "Desarrollo y mantenimiento de sistemas web internos con JavaScript, Angular y SQL Server. Participación en proyectos nuevos, implementación de políticas según normas ISO y mejores prácticas de desarrollo.",
    },
    {
      title: "Especialista IT",
      company: "Schnellecke Logistics / Danone",
      period: "Jul 2021 - Jul 2023",
      description:
        "Mantenimiento de la operación ininterrumpida de sistemas. Soporte y administración de redes, equipos de cómputo e infraestructura tecnológica. Resolución de incidencias técnicas.",
    },
  ],
} = Astro.props;
---

<section id="curriculum" class="curriculum">
  <div class="contenido-seccion">
    <h2>Currículum</h2>
    <div class="fila">
      <!-- Educación -->
      <div class="col izquierda">
        <h3>Educación</h3>
        {
          education.map(
            (edu: {
              title: string;
              institution: string;
              period: string;
              description: string;
            }) => (
              <div class="item izq">
                <h4>{edu.title}</h4>
                <span class="casa">{edu.institution}</span>
                <span class="fecha">{edu.period}</span>
                <p>{edu.description}</p>
                <div class="conectori">
                  <div class="circuloi" />
                </div>
              </div>
            ),
          )
        }
      </div>

      <!-- Experiencia de trabajo -->
      <div class="col derecha">
        <h3>Experiencia de trabajo</h3>
        {
          workExperience.map(
            (job: {
              title: string;
              company: string;
              period: string;
              description: string;
            }) => (
              <div class="item der">
                <h4>{job.title}</h4>
                <span class="casa">{job.company}</span>
                <span class="fecha">{job.period}</span>
                <p>{job.description}</p>
                <div class="conectord">
                  <div class="circulod" />
                </div>
              </div>
            ),
          )
        }
      </div>
    </div>
  </div>
</section>
