---
import { Github, Linkedin, ChevronsUp } from '@lucide/astro';

const iconMap: Record<string, any> = {
  github: Github,
  linkedin: Linkedin,
};

const socialLinks = [
  { href: "https://github.com/ngMigthy-astro", icon: "github", label: "GitHub" },
  { href: "https://linkedin.com", icon: "linkedin", label: "LinkedIn" },
];
---

<footer>
  <a href="#inicio" class="arriba" aria-label="Ir arriba">
    <ChevronsUp size={20} />
  </a>

  <nav class="redes">
    {
      socialLinks.map((link) => {
        const IconComponent = iconMap[link.icon];
        return (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={link.label}
          >
            {IconComponent && <IconComponent size={20} />}
          </a>
        );
      })
    }
  </nav>
</footer>
