---
const projects = [
  {
    title: "Portal Jurídico - Sec. de Finanzas",
    description: "Angular · TypeScript",
    imageSrc: "/img/projects/portal-finanzas.jpg",
    alt: "Portal público de la Secretaría de Finanzas del Estado de Guanajuato",
  },
  {
    title: "Holiday Inn - Dashboard",
    description: "Angular · SQL Server",
    imageSrc: "/img/projects/holidayinn-dashboard.jpg",
    alt: "Dashboard de métricas y tickets para Holiday Inn Irapuato",
  },
  {
    title: "Holiday Inn - Gestión de Usuarios",
    description: "Angular · CRUD · Filtros",
    imageSrc: "/img/projects/holidayinn-usuarios.jpg",
    alt: "Sistema de gestión de usuarios para Holiday Inn Irapuato",
  },
  {
    title: "Generador QR",
    description: "JavaScript · Canvas API",
    imageSrc: "/img/projects/generador-qr.jpg",
    alt: "Generador de códigos QR con personalización",
  },
  {
    title: "El Archivo Simpsons",
    description: "JavaScript · API REST · Zod",
    imageSrc: "/img/projects/simpsons-api.jpg",
    alt: "Aplicación de consulta de personajes de Los Simpsons",
  },
];
---

<section id="portfolio" class="portfolio">
  <div class="contenido-seccion">
    <h2>PORTFOLIO</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        projects.map((project) => (
          <div class="proyecto relative group overflow-hidden rounded-lg cursor-pointer">
            <img
              src={project.imageSrc}
              alt={project.alt}
              class="w-full h-56 object-cover block transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-[rgba(28,182,152,0.85)] flex flex-col items-center justify-center text-white opacity-0 group-hover:opacity-100 transition-opacity duration-500">
              <h3 class="text-xl font-bold mb-1 font-['Righteous']">{project.title}</h3>
              <p class="text-sm tracking-wider">{project.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
